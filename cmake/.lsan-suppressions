# LeakSanitizer suppressions for known false positives.
# See: https://github.com/google/sanitizers/wiki/AddressSanitizerLeakSanitizer

# libuv and OpenSSL may hold memory at exit in worker threads or
# internal caches that are not freed before process termination.
# These are not application leaks.

leak:libuv
leak:OPENSSL_init
leak:CRYPTO_
leak:BIO_
leak:SSL_

# libcurl internal state held at exit (test_ai)
leak:curl_

# nghttp2 internal buffers may be held at exit
leak:nghttp2_session
leak:nghttp2_

# pthread internals (macOS libc)
leak:pthread_

# Python internals (when using ctypes)
leak:PyMem_RawMalloc
leak:PyObject_Malloc
leak:_PyObject_Malloc
leak:_PyMem_RawMalloc
leak:PyMem_Malloc
leak:_PyBytes_Resize
leak:PyType_Ready
leak:Py_Initialize

# test_integration: a single outstanding client write can remain queued
# at server shutdown if the process exits before the cancellation callback
# runs. This is a known shutdown-timing edge case, not a functional leak.
leak:csilk_client_write
