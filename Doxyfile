# Doxyfile 1.12.0
PROJECT_NAME           = "Csilk"
PROJECT_NUMBER         = 0.2.0
PROJECT_BRIEF          = "A lightweight, high-performance C HTTP web framework"
OUTPUT_DIRECTORY       = docs
INPUT                  = include src README.md examples/example_app.c examples/example_server.c examples/advanced_server.c
RECURSIVE              = YES
FILE_PATTERNS          = *.h *.c *.md
EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES
EXTRACT_PRIVATE        = NO
EXTRACT_PACKAGE        = NO
CASE_SENSE_NAMES       = YES
INPUT_ENCODING         = UTF-8
USE_MDFILE_AS_MAINPAGE = README.md
GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES
WARN_FORMAT            = "$file:$line: $text"
CLANG_ASSISTED_PARSING = YES
CLANG_DATABASE_PATH    = build
QUIET                  = NO
JAVADOC_AUTOBRIEF      = NO
QT_AUTOBRIEF           = NO
MULTILINE_CPP_IS_BRIEF = NO
INHERIT_DOCS           = YES
SEPARATE_MEMBER_PAGES  = NO
TAB_SIZE               = 4
ALIASES                =
OPTIMIZE_OUTPUT_FOR_C  = YES
OPTIMIZE_OUTPUT_JAVA   = NO
OPTIMIZE_FOR_FORTRAN   = NO
OPTIMIZE_OUTPUT_VHDL   = NO
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
BUILTIN_STL_SUPPORT    = NO
CPP_CLI_SUPPORT        = NO
SIP_SUPPORT            = NO
IDL_PROPERTY_SUPPORT   = NO
DISTRIBUTE_GROUP_DOC   = YES
GROUP_NESTED_COMPOUNDS = NO
SUBGROUPING            = YES
INLINE_GROUPED_CLASSES = NO
INLINE_SIMPLE_STRUCTS  = YES
TYPEDEF_HIDES_STRUCT   = YES
LOOKUP_CACHE_SIZE      = 0
NUM_PROC_THREADS       = 0
DOT_CLEANUP            = YES
