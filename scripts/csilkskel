#!/usr/bin/env python3
"""
csilk scaffold — Generate a new csilk project from templates.

Interactive by default; accepts flags for scripting/CI usage.

Usage:
    csilkskel                          # Interactive mode
    csilkskel --name myapp             # Named project, interactive
    csilkskel --name myapp --output .  # Generate in current directory
    csilkskel --name myapp --type api --port 3000  # Non-interactive

Project types:
    basic    Minimal Hello World server
    api      REST API with JSON, params, groups, middleware
    workflow AI workflow with tool calling
    admin    Full admin dashboard with WebSocket monitoring
"""

import argparse
import os
import re
import shutil
import sys
import textwrap

VERSION = "0.4.0"

# ─── color helpers ──────────────────────────────────────────────────
def bold(s):   return f"\033[1m{s}\033[0m"
def green(s):  return f"\033[32m{s}\033[0m"
def blue(s):   return f"\033[34m{s}\033[0m"
def yellow(s): return f"\033[33m{s}\033[0m"
def red(s):    return f"\033[31m{s}\033[0m"

def ask(question, default=None):
    """Prompt with a default value."""
    if default:
        q = f"{question} [{default}]: "
    else:
        q = f"{question}: "
    answer = input(q).strip()
    return answer if answer else default

def ask_yn(question, default=True):
    suffix = "Y/n" if default else "y/N"
    answer = input(f"{question} [{suffix}]: ").strip().lower()
    if not answer:
        return default
    return answer.startswith("y")

# ─── template generators ─────────────────────────────────────────────

def generate_cmake(project_name, port):
    return f"""cmake_minimum_required(VERSION 3.16)
project({project_name} C)

set(CMAKE_C_STANDARD 23)
set(CMAKE_C_STANDARD_REQUIRED ON)

include(FetchContent)
FetchContent_Declare(
    csilk
    GIT_REPOSITORY  https://github.com/quintin-lee/csilk.git
    GIT_TAG         v{VERSION}
)
FetchContent_MakeAvailable(csilk)

file(GLOB_RECURSE SOURCES src/*.c)

add_executable({project_name} ${{SOURCES}})
target_link_libraries({project_name} PRIVATE csilk)
target_include_directories({project_name} PRIVATE src include)

configure_file(config.yaml config.yaml COPYONLY)
"""

def config_yaml(port):
    return f"""port: {port}
server:
  idle_timeout_ms: 30000
  read_timeout_ms:  30000
  write_timeout_ms: 30000
  max_body_size: 1048576
  max_header_size: 65536
  worker_threads: 4
  tcp_nodelay: 1

logger:
  level: INFO
  use_colors: 1

middleware:
  enable_recovery: 1
  enable_logger: 1

static_files:
  enable: 1
  root_dir: "./public"
  prefix: "/static"
"""

def basic_main(project_name, port):
    return f"""/**
 * @file main.c
 * @brief {project_name} — generated by csilk scaffold.
 */
#include "csilk/csilk.h"

static void hello(csilk_ctx_t* c) {{
    csilk_string(c, 200, "Hello from {project_name}!");
}}

static void healthz(csilk_ctx_t* c) {{
    csilk_json_error(c, 200, "ok");
}}

int main(void) {{
    csilk_router_t* r = csilk_router_new();
    csilk_router_add(r, "GET", "/",        (csilk_handler_t[]){{hello}},   1);
    csilk_router_add(r, "GET", "/healthz", (csilk_handler_t[]){{healthz}}, 1);

    csilk_server_t* s = csilk_server_new(r);
    csilk_server_run(s, 8080);
    return 0;
}}
"""

def api_main(project_name, port):
    return f"""/**
 * @file main.c
 * @brief {project_name} — REST API server.
 */
#include "csilk/csilk.h"
#include "handlers.h"

int main(void) {{
    csilk_router_t* r = csilk_router_new();

    /* API v1 group */
    csilk_group_t* api = csilk_group_new(r, "/api/v1");
    csilk_group_use(api, csilk_logger_handler);
    csilk_group_use(api, csilk_recovery_handler);

    csilk_GET(api, "/health",  health_handler);
    csilk_GET(api, "/users",   list_users_handler);
    csilk_GET(api, "/users/:id", get_user_handler);
    csilk_POST(api, "/users",  create_user_handler);

    csilk_app_t* app = csilk_app_new(r);
    csilk_admin_serve(app, "/admin");

    csilk_server_t* s = csilk_server_new(r);
    csilk_server_run(s, {port});
    return 0;
}}
"""

def api_handlers_h():
    return """/**
 * @file handlers.h
 * @brief API route handlers.
 */
#include "csilk/csilk.h"

void health_handler(csilk_ctx_t* c);
void list_users_handler(csilk_ctx_t* c);
void get_user_handler(csilk_ctx_t* c);
void create_user_handler(csilk_ctx_t* c);
"""

def api_handlers_c():
    return r"""/**
 * @file handlers.c
 * @brief API route handler implementations.
 */
#include <stdio.h>
#include "cJSON.h"
#include "handlers.h"

void health_handler(csilk_ctx_t* c) {
    cJSON* root = cJSON_CreateObject();
    cJSON_AddStringToObject(root, "status", "healthy");
    cJSON_AddNumberToObject(root, "uptime", 0);
    csilk_json(c, 200, root);
}

/* ── in-memory user store (demo only) ─────────────────────────── */
typedef struct { int id; char name[64]; char email[128]; } User;
static User users[] = {
    {1, "Alice",   "alice@example.com"},
    {2, "Bob",     "bob@example.com"},
    {3, "Charlie", "charlie@example.com"},
};
static const int user_count = 3;

void list_users_handler(csilk_ctx_t* c) {
    cJSON* arr = cJSON_CreateArray();
    for (int i = 0; i < user_count; i++) {
        cJSON* u = cJSON_CreateObject();
        cJSON_AddNumberToObject(u, "id",   users[i].id);
        cJSON_AddStringToObject(u, "name",  users[i].name);
        cJSON_AddStringToObject(u, "email", users[i].email);
        cJSON_AddItemToArray(arr, u);
    }
    cJSON* root = cJSON_CreateObject();
    cJSON_AddItemToObject(root, "users", arr);
    csilk_json(c, 200, root);
}

void get_user_handler(csilk_ctx_t* c) {
    const char* id_str = csilk_get_param(c, "id");
    int id = id_str ? atoi(id_str) : 0;
    for (int i = 0; i < user_count; i++) {
        if (users[i].id == id) {
            cJSON* u = cJSON_CreateObject();
            cJSON_AddNumberToObject(u, "id",   users[i].id);
            cJSON_AddStringToObject(u, "name",  users[i].name);
            cJSON_AddStringToObject(u, "email", users[i].email);
            csilk_json(c, 200, u);
            return;
        }
    }
    csilk_json_error(c, 404, "user not found");
}

void create_user_handler(csilk_ctx_t* c) {
    cJSON* body = csilk_bind_json(c);
    if (!body) {
        csilk_json_error(c, 400, "invalid JSON body");
        return;
    }
    cJSON* name = cJSON_GetObjectItem(body, "name");
    cJSON* email = cJSON_GetObjectItem(body, "email");
    cJSON* out = cJSON_CreateObject();
    cJSON_AddNumberToObject(out, "id", user_count + 1);
    cJSON_AddStringToObject(out, "name",  name ? name->valuestring : "");
    cJSON_AddStringToObject(out, "email", email ? email->valuestring : "");
    cJSON_AddStringToObject(out, "status", "created");
    cJSON_Delete(body);
    csilk_json(c, 201, out);
}
"""

def workflow_main(project_name, port):
    return f"""/**
 * @file main.c
 * @brief {project_name} — AI workflow server.
 */
#include "csilk/csilk.h"

static void run_workflow(csilk_ctx_t* c) {{
    csilk_string(c, 200, "Workflow endpoint ready. Define nodes in your workflow.");
}}

int main(void) {{
    csilk_router_t* r = csilk_router_new();

    csilk_router_add(r, "GET",  "/",        (csilk_handler_t[]){{run_workflow}}, 1);
    csilk_router_add(r, "POST", "/workflow", (csilk_handler_t[]){{run_workflow}}, 1);

    csilk_app_t* app = csilk_app_new(r);
    csilk_admin_serve(app, "/admin");

    csilk_server_t* s = csilk_server_new(r);
    csilk_server_run(s, {port});
    return 0;
}}
"""

def admin_main(project_name, port):
    return f"""/**
 * @file main.c
 * @brief {project_name} — Admin dashboard server.
 */
#include "csilk/csilk.h"

static void index_page(csilk_ctx_t* c) {{
    csilk_string(c, 200,
        "<html><head><title>{project_name}</title></head>"
        "<body><h1>{project_name}</h1>"
        "<p><a href='/admin'>Admin Dashboard</a></p>"
        "<p><a href='/metrics'>Prometheus Metrics</a></p>"
        "<p><a href='/openapi.json'>OpenAPI Spec</a></p>"
        "</body></html>");
}}

int main(void) {{
    csilk_router_t* r = csilk_router_new();
    csilk_router_add(r, "GET", "/", (csilk_handler_t[]){{index_page}}, 1);

    csilk_app_t* app = csilk_app_new(r);
    csilk_app_enable_openapi(app, "{project_name}", "0.1.0", "Scaffolded admin server");
    csilk_admin_serve(app, "/admin");

    csilk_server_t* s = csilk_server_new(r);
    csilk_server_run(s, {port});
    return 0;
}}
"""

def readme(name, project_type, port):
    return f"""# {name}

Generated by **csilk scaffold** v{VERSION}.

Type: `{project_type}` | Port: `{port}`

## Build & Run

```bash
mkdir build && cd build
cmake ..
make
./{name}
```

Then open http://localhost:{port}/

## Project Structure

```
src/
  main.c            Entry point
  handlers.{'{'}c,h{'}'}   Route handlers (api type)
public/             Static files
config.yaml         Server configuration
CMakeLists.txt      Build file
```

## Learn More

- [csilk GitHub](https://github.com/quintin-lee/csilk)
- API Reference: https://quintin-lee.github.io/csilk/
"""


# ─── main ────────────────────────────────────────────────────────────

TYPES = {
    "basic":    {"desc": "Minimal Hello World server",                 "main": basic_main},
    "api":      {"desc": "REST API with JSON, params, groups, admin",  "main": api_main},
    "workflow": {"desc": "AI workflow with tool calling",              "main": workflow_main},
    "admin":    {"desc": "Admin dashboard with WebSocket monitoring",  "main": admin_main},
}

def main():
    parser = argparse.ArgumentParser(
        prog="csilkskel",
        description=f"csilk scaffold v{VERSION} — generate a new csilk project",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="Run without arguments for interactive mode."
    )
    parser.add_argument("--name",    help="Project name (lowercase, underscores)")
    parser.add_argument("--output",  help="Output directory (default: ./<name>)")
    parser.add_argument("--type",    choices=list(TYPES), help="Project type")
    parser.add_argument("--port",    type=int, default=8080, help="Server port (default: 8080)")
    parser.add_argument("--quiet",   action="store_true", help="Skip confirmation prompt")
    args = parser.parse_args()

    # ── banner ──
    print(f"""
{blue('╔══════════════════════════════════════════╗')}
{blue('║')}       {bold('csilk scaffold')}  {f'v{VERSION}':>10}           {blue('║')}
{blue('╚══════════════════════════════════════════╝')}
""")

    # ── interactive ──
    name = args.name
    if not name:
        print("\nLet's create a new csilk project!\n")
        print("Available types:")
        for k, v in TYPES.items():
            print(f"  {green(k):12} {v['desc']}")
        print()

        name = ask("Project name")
        while not name or not re.match(r'^[a-z][a-z0-9_]*$', name):
            name = ask("Project name (lowercase letters, numbers, underscores)")

    # Validate name
    if not re.match(r'^[a-z][a-z0-9_]*$', name):
        print(f"{red('Error:')} project name must be lowercase letters/numbers/underscores, starting with a letter")
        sys.exit(1)

    output = args.output or f"./{name}"
    if output == ".":
        output = os.getcwd()

    ptype = args.type or ask("Project type", "api")
    if ptype not in TYPES:
        print(f"{red('Error:')} unknown type '{ptype}'. Choose: {', '.join(TYPES)}")
        sys.exit(1)

    port = args.port

    # ── confirmation ──
    print(f"\n  {bold('Project')}: {green(name)}")
    print(f"  {bold('Type')}:    {TYPES[ptype]['desc']}")
    print(f"  {bold('Port')}:    {port}")
    print(f"  {bold('Output')}:  {output}")
    print()

    if not args.quiet:
        if not ask_yn("Create project?", True):
            print("Aborted.")
            sys.exit(0)

    # ── generate ──
    src_dir = os.path.join(output, "src")
    public_dir = os.path.join(output, "public")

    os.makedirs(output, exist_ok=True)
    os.makedirs(src_dir, exist_ok=True)
    os.makedirs(public_dir, exist_ok=True)

    def write(path, content):
        with open(os.path.join(output, path), "w") as f:
            f.write(textwrap.dedent(content).lstrip())
        print(f"  {green('✓')} {path}")

    write("CMakeLists.txt", generate_cmake(name, port))
    write("config.yaml", config_yaml(port))
    write("README.md", readme(name, ptype, port))
    write("src/main.c", TYPES[ptype]["main"](name, port))

    if ptype == "api":
        write("src/handlers.h", api_handlers_h())
        write("src/handlers.c", api_handlers_c())

    touch_files = [".gitkeep"]
    for f in touch_files:
        fp = os.path.join(public_dir, f)
        with open(fp, "w") as fh:
            pass
        print(f"  {green('✓')} public/{f}")

    print(f"\n{bold('Done!')}  Run these commands to build and start:\n")
    print(f"  {blue('cd')} {output}")
    print(f"  {blue('mkdir build && cd build')}")
    print(f"  {blue('cmake .. && make')}")
    print(f"  {blue(f'./{name}')}")
    print()

if __name__ == "__main__":
    main()
