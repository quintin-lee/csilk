#!/bin/bash
set -e

CSILK_VERSION="8ce90cc"
AI_PROVIDER="none"
USE_CIPHER="0"
MID_REQUESTID="n"

LOCAL_REMOTE=$(git config --get remote.origin.url 2>/dev/null || true)
if echo "$LOCAL_REMOTE" | grep -qE 'github\.com[/:](.+)/(.+)\.git'; then
  LOCAL_REPO_PATH=$(echo "$LOCAL_REMOTE" | sed -E 's|.*github\.com[/:](.+)/(.+)\.git|\1/\2|')
  CSILK_REPO_DEFAULT="https://github.com/${LOCAL_REPO_PATH}.git"
else
  CSILK_REPO_DEFAULT="https://github.com/quintin-lee/csilk.git"
fi

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; BOLD='\033[1m'; NC='\033[0m'

log_info() { echo -e "${BLUE}[INFO]${NC} $1" >&2; }
log_success() { echo -e "${GREEN}[SUCCESS]${NC} $1" >&2; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1" >&2; }
log_error() { echo -e "${RED}[ERROR]${NC} $1" >&2; }
log_step() { echo -e "\n${BLUE}==>${NC} ${BOLD}${1}${NC}" >&2; }

print_banner() {
  cat <<'EOF'
╔══════════════════════════════════════════╗
║           csilk scaffold tool            ║
║     Generate a new csilk project         ║
╚══════════════════════════════════════════╝
EOF
}

ask() {
  local prompt="$1" default="$2" var
  printf "  ${BOLD}%s${NC} [%s]: " "$prompt" "$default" >&2
  read -r var
  echo "${var:-$default}"
}

ask_yes() {
  local prompt="$1" default="$2" ans
  printf "  ${BOLD}%s${NC} [%s]: " "$prompt" "$default" >&2
  read -r ans
  ans="${ans:-$default}"
  case "$ans" in [Yy]*) return 0 ;; *) return 1 ;; esac
}

pick() {
  local prompt="$1" default="$2" desc="$3"
  echo -e "  ${BOLD}${prompt}${NC}" >&2
  echo "$desc" | while IFS='|' read -r key label; do
    if [ -n "$key" ]; then printf "    ${BLUE}%s)${NC} %s\n" "$key" "$label" >&2; fi
  done
  printf "  choice [%s]: " "$default" >&2
  read -r ans
  echo "${ans:-$default}"
}

show_help() {
  cat <<EOF
Usage: csilkskel [options]

Options:
-h, --help             Show this help message
-n, --name NAME        Project name (default: myapp)
-o, --out-dir DIR      Output directory (default: ./<name>)
-p, --port PORT        Port number (default: 8080)
--api-style STYLE      API style: app, core (default: app)
--db DB                Database: sqlite, mysql, postgres, none (default: sqlite)
--ai PROVIDER          AI driver: none, openai, ollama (default: none)
--cipher               Enable OpenSSL cipher driver
--auth AUTH            Auth: none, jwt, token (default: none)
--use-perm             Enable permission system
--use-swagger          Enable Swagger/OpenAPI
--middleware LIST      Comma-separated (cors,gzip,ratelimit,session,requestid,csrf)
--use-ws               WebSocket chat example
--use-sse              SSE event stream example
--use-admin            Admin dashboard (/admin)
--use-workflow         AI Workflow example
--use-metrics          Prometheus metrics (/metrics)
--use-upload           Multipart file upload example
--use-spa              SPA fallback (serve index.html)
--use-hooks            Server lifecycle hooks example
--use-mq               Message Queue example
--git                  Initialize git repository
--non-interactive      Skip prompts and use defaults for missing values

Example:
  csilkskel -n myapp -p 9090 --db mysql --ai openai --middleware cors,gzip --use-ws --use-admin --git
EOF
}

validate_inputs() {
  if [[ ! "$PROJECT_NAME" =~ ^[a-zA-Z_][a-zA-Z0-9_]*$ ]]; then
    log_error "Project name must be a valid C identifier (letters, numbers, underscores, starting with letter/underscore)."
    exit 1
  fi
  if ! [[ "$PORT" =~ ^[0-9]+$ ]] || [ "$PORT" -lt 1 ] || [ "$PORT" -gt 65535 ]; then
    log_error "Port must be a number between 1 and 65535."
    exit 1
  fi
  if [ -d "$OUT_DIR" ] && [ "$(ls -A "$OUT_DIR" 2>/dev/null)" ]; then
    log_warn "Output directory '$OUT_DIR' already exists and is not empty."
    if [ "$NON_INTERACTIVE" -eq 1 ]; then log_error "Aborting due to non-interactive mode."; exit 1; fi
    if ! ask_yes "Continue anyway and potentially overwrite files?" "n"; then exit 1; fi
  fi
}

prepare_vars() {
  BUILD_DB=""; LINK_DB=""; HDR_DB=""; SETUP_DB=""; CLEANUP_DB=""; USE_DB_EXEC=""
  if [ "$DB" = "mysql" ]; then
    BUILD_DB='find_library(MYSQL_LIB NAMES mysqlclient libmysqlclient)
if(NOT MYSQL_LIB)
  message(FATAL_ERROR "libmysqlclient not found")
endif()
find_path(MYSQL_INCLUDE_DIR mysql.h PATHS /usr/include/mysql /usr/local/include/mysql)
if(MYSQL_INCLUDE_DIR)
  include_directories(${MYSQL_INCLUDE_DIR})
endif()'
    LINK_DB=' ${MYSQL_LIB}'
    HDR_DB='#include "csilk/drivers/db.h"'
    SETUP_DB='  csilk_db_init();'
    CLEANUP_DB='  if (pool) csilk_db_pool_free(pool);'
    USE_DB_EXEC='  csilk_db_pool_t* pool = csilk_db_pool_new("mysql", "host=127.0.0.1;port=3306;user=root;password=secret;dbname='"${PROJECT_NAME}"'");'
  elif [ "$DB" = "postgres" ]; then
    BUILD_DB='find_library(PQ_LIB NAMES pq libpq)
if(NOT PQ_LIB)
  message(FATAL_ERROR "libpq not found")
endif()'
    LINK_DB=' ${PQ_LIB}'
    HDR_DB='#include "csilk/drivers/db.h"'
    SETUP_DB='  csilk_db_init();'
    CLEANUP_DB='  if (pool) csilk_db_pool_free(pool);'
    USE_DB_EXEC='  csilk_db_pool_t* pool = csilk_db_pool_new("postgres", "host=127.0.0.1 port=5432 user=postgres password=secret dbname='"${PROJECT_NAME}"'");'
  elif [ "$DB" = "sqlite" ]; then
    BUILD_DB=''; LINK_DB=''
    HDR_DB='#include "csilk/drivers/db.h"'
    SETUP_DB='  csilk_db_init();'
    CLEANUP_DB='  if (pool) csilk_db_pool_free(pool);'
    USE_DB_EXEC='  csilk_db_pool_t* pool = csilk_db_pool_new("sqlite", "'"${PROJECT_NAME}"'.db");'
  fi

  AUTH_HDR=""; AUTH_SETUP=""; AUTH_MID=""
  if [ "$AUTH" = "jwt" ]; then
    AUTH_MID='  csilk_app_use(app, jwt_middleware_wrapper);'
  elif [ "$AUTH" = "token" ]; then
    AUTH_MID='  csilk_app_use(app, auth_middleware_wrapper);'
  fi

  PERM_HDR=""; PERM_INIT=""; PERM_MID=""; PERM_ROUTES=""; PERM_RULES=""
  if [ "$USE_PERM" = "1" ]; then
    PERM_HDR='#include "csilk/drivers/perm.h"'
    PERM_INIT='  csilk_perm_init();
  csilk_perm_simple_allow("admin", "*", "*");
  csilk_perm_simple_allow("user", "read", "*");
  csilk_perm_set_default("simple");'
    PERM_MID='  csilk_app_use(app, csilk_perm_auto_middleware);'
    PERM_ROUTES='csilk_app_get_perm(app, "/admin", admin_handler, "admin", "*");'
  fi

  SWAGGER_SETUP=""
  if [ "$USE_SWAGGER" = "1" ]; then
    SWAGGER_SETUP='  csilk_app_enable_openapi(app, 1);'
  fi

  # Base source files
  LAYERED_SOURCES="  src/main.c
  src/api/user_handler.c
  src/service/user_service.c
  src/model/user.c"

  AI_HDR=""; AI_SETUP=""; AI_CLEANUP=""; AI_GLOBALS=""; AI_FUNCS=""
  if [ "$AI_PROVIDER" != "none" ]; then
    AI_HDR='#include "csilk/drivers/ai.h"'
    AI_GLOBALS="static csilk_ai_t* ai = NULL;\nstatic csilk_ai_context_t* ai_ctx = NULL;"
    AI_FUNCS='static void ai_injector_middleware(csilk_ctx_t* c) {
  csilk_set(c, "ai", ai);
  csilk_set(c, "ai_ctx", ai_ctx);
}'
    AI_SETUP='  csilk_config_t* cfg = csilk_app_config(app);
  if (cfg) {
    ai = csilk_ai_new(cfg->ai.driver, cfg->ai.api_key, cfg->ai.base_url);
    if (ai) {
      ai_ctx = csilk_ai_context_new(10);
    }
    csilk_config_free(cfg);
    free(cfg);
  }
  csilk_app_use(app, ai_injector_middleware);'
    AI_CLEANUP='  csilk_ai_free(ai);
  csilk_ai_context_free(ai_ctx);'
    LAYERED_SOURCES="${LAYERED_SOURCES}
  src/api/ai_handler.c"
  fi

  CIPHER_HDR=""; CIPHER_SETUP=""
  if [ "$USE_CIPHER" = "1" ]; then
    CIPHER_HDR='#include "csilk/drivers/cipher.h"'
    CIPHER_SETUP='  extern csilk_cipher_driver_t csilk_default_cipher_driver;
  csilk_server_set_cipher_driver(csilk_app_server(app), &csilk_default_cipher_driver);'
  fi

  # ── WebSocket ──
  WS_HDR=""; WS_ROUTES=""
  if [ "$USE_WS" = "1" ]; then
    WS_ROUTES='  csilk_app_get(app, "/ws", csilk_ws_handshake);
  csilk_app_get(app, "/ws-chat", ws_chat_handler);'
    LAYERED_SOURCES="${LAYERED_SOURCES}
  src/api/ws_handler.c"
  fi

  # ── SSE ──
  SSE_HDR=""; SSE_ROUTES=""
  if [ "$USE_SSE" = "1" ]; then
    SSE_ROUTES='  csilk_app_get(app, "/events", sse_events_handler);'
    LAYERED_SOURCES="${LAYERED_SOURCES}
  src/api/sse_handler.c"
  fi

  # ── Admin Dashboard ──
  ADMIN_HDR=""; ADMIN_SETUP=""
  if [ "$USE_ADMIN" = "1" ]; then
    ADMIN_HDR='#include "csilk/app/admin.h"'
    ADMIN_SETUP='  csilk_admin_serve(app, "/admin");'
  fi

  # ── AI Workflow ──
  WORKFLOW_HDR=""; WORKFLOW_FUNCS=""; WORKFLOW_SETUP=""; WORKFLOW_ROUTES=""
  if [ "$USE_WORKFLOW" = "1" ]; then
    WORKFLOW_HDR='#include "csilk/app/workflow.h"'
    WORKFLOW_FUNCS=""
    WORKFLOW_SETUP='  csilk_wf_serve_ui(app, "/workflow");'
    WORKFLOW_ROUTES='  csilk_app_get(app, "/wf-demo", workflow_demo_handler);'
    LAYERED_SOURCES="${LAYERED_SOURCES}
  src/api/workflow_handler.c"
  fi

  # ── Metrics ──
  METRICS_MID=""; METRICS_ROUTES=""
  if [ "$USE_METRICS" = "1" ]; then
    METRICS_MID='  csilk_app_use(app, csilk_metrics_middleware_wrapper);'
    METRICS_ROUTES='  csilk_app_get(app, "/metrics", csilk_metrics_handler);'
  fi

  # ── CSRF ──
  CSRF_MID=""
  if [ "$MID_CSRF" = "y" ]; then
    CSRF_MID='  csilk_app_use(app, csilk_csrf_middleware);'
  fi

  # ── Multipart Upload ──
  UPLOAD_HDR=""; UPLOAD_ROUTES=""
  if [ "$USE_UPLOAD" = "1" ]; then
    UPLOAD_ROUTES='  csilk_app_post(app, "/upload", upload_handler);'
    LAYERED_SOURCES="${LAYERED_SOURCES}
  src/api/upload_handler.c"
  fi

  # ── SPA Fallback ──
  SPA_SETUP=""
  if [ "$USE_SPA" = "1" ]; then
    SPA_SETUP='  csilk_server_set_spa_fallback(csilk_app_server(app), "index.html");'
  fi

  # ── Hooks ──
  HOOKS_FUNCS=""; HOOKS_SETUP=""
  if [ "$USE_HOOKS" = "1" ]; then
    HOOKS_FUNCS='static void on_server_start(csilk_server_t* s) {
  fprintf(stderr, "[hook] server started\\n");
}
static void on_server_stop(csilk_server_t* s) {
  fprintf(stderr, "[hook] server stopping\\n");
}'
    HOOKS_SETUP='  csilk_server_add_hook(csilk_app_server(app), CSILK_HOOK_SERVER_START, on_server_start);
  csilk_server_add_hook(csilk_app_server(app), CSILK_HOOK_SERVER_STOP, on_server_stop);'
  fi

  # ── Message Queue ──
  MQ_HDR=""; MQ_FUNCS=""; MQ_SETUP=""; MQ_CLEANUP=""; MQ_GLOBALS=""
  if [ "$USE_MQ" = "1" ]; then
    MQ_GLOBALS="static csilk_mq_t* mq = NULL;"
    MQ_FUNCS='static void mq_handler(csilk_mq_ctx_t* ctx) {
  size_t len = 0;
  const void* payload = csilk_mq_get_payload(ctx, &len);
  fprintf(stderr, "[mq] topic=%s payload=%.*s\\n",
          csilk_mq_get_topic(ctx), (int)len, (const char*)payload);
  csilk_mq_next(ctx);
}'
    MQ_SETUP='  mq = csilk_server_get_mq(csilk_app_server(app));
  csilk_mq_subscribe(mq, "events", mq_handler);
  csilk_mq_subscribe(mq, "notifications", mq_handler);'
  fi

  MID_SETUP=""
  if [ "$MID_CORS" = "y" ]; then MID_SETUP="${MID_SETUP}  csilk_app_use(app, cors_middleware_wrapper);\n"; fi
  if [ "$MID_GZIP" = "y" ]; then MID_SETUP="${MID_SETUP}  csilk_app_use(app, csilk_gzip_middleware);\n"; fi
  if [ "$MID_RATELIMIT" = "y" ]; then MID_SETUP="${MID_SETUP}  csilk_app_use(app, ratelimit_middleware_wrapper);\n"; fi
  if [ "$MID_SESSION" = "y" ]; then MID_SETUP="${MID_SETUP}  csilk_app_use(app, csilk_session_start);\n"; fi
  if [ "$MID_REQUESTID" = "y" ]; then MID_SETUP="${MID_SETUP}  csilk_app_use(app, csilk_request_id_middleware);\n"; fi
}

generate_gitignore() {
  cat > .gitignore <<GITIGNORE
build/
bin/
lib/
*.o
*.so
*.a
compile_commands.json
.cache/
.vscode/
.idea/
.clangd/
*.db
GITIGNORE
}

generate_config() {
  cat > config.yaml <<YAML
port: ${PORT}
server:
  idle_timeout_ms: 5000
  read_timeout_ms: 30000
  write_timeout_ms: 30000
  max_body_size: 1048576
  max_header_size: 65536
  max_url_size: 8192
  max_headers_count: 100
  max_connections: 0
  listen_backlog: 128
  tcp_nodelay: 1
  worker_threads: 4
logger:
  level: DEBUG
middleware:
  enable_logger: 1
  enable_recovery: 1
  enable_request_id: $([ "$MID_REQUESTID" = "y" ] && echo "1" || echo "0")
YAML
  if [ "$AI_PROVIDER" != "none" ]; then
    cat >> config.yaml <<YAML
ai:
  driver: ${AI_PROVIDER}
  model: $([ "$AI_PROVIDER" = "openai" ] && echo "gpt-4o" || echo "llama3")
  api_key: "\${$(echo ${AI_PROVIDER} | tr '[:lower:]' '[:upper:]')_API_KEY}"
  base_url: ""
YAML
  fi
  if [ "$DB" = "sqlite" ]; then
    cat >> config.yaml <<YAML
db:
  driver: sqlite
  dsn: ${PROJECT_NAME}.db
YAML
  fi
}

generate_cmake() {
  local OPENSSL_FIND=""; local OPENSSL_LINK=""
  if [ "$USE_CIPHER" = "1" ]; then
    OPENSSL_FIND="find_package(OpenSSL REQUIRED)"
    OPENSSL_LINK=" OpenSSL::Crypto"
  fi
  cat > CMakeLists.txt <<CMAKE
cmake_minimum_required(VERSION 3.11)
project(${PROJECT_NAME} C)

set(CMAKE_C_STANDARD 11)
set(CMAKE_EXPORT_COMPILE_COMMANDS ON)

find_package(csilk QUIET
  HINTS \${CSILK_DIR} /usr/local /usr
  PATH_SUFFIXES lib/cmake/csilk
)

if(NOT csilk_FOUND)
  if(CSILK_SOURCE_DIR)
    set(_csilk_deps_dir "\${CSILK_SOURCE_DIR}/build/_deps")
    if(EXISTS "\${_csilk_deps_dir}/libuv-src/CMakeLists.txt")
      set(FETCHCONTENT_SOURCE_DIR_LIBUV "\${_csilk_deps_dir}/libuv-src" CACHE PATH "" FORCE)
    endif()
    if(EXISTS "\${_csilk_deps_dir}/cjson-src/CMakeLists.txt")
      set(FETCHCONTENT_SOURCE_DIR_CJSON "\${_csilk_deps_dir}/cjson-src" CACHE PATH "" FORCE)
    endif()
    add_subdirectory(\${CSILK_SOURCE_DIR} \${CMAKE_BINARY_DIR}/csilk)
    set(CSILK_LIB csilk)
  else()
    include(FetchContent)
    FetchContent_Declare(csilk
      GIT_REPOSITORY ${CSILK_REPO_DEFAULT}
      GIT_TAG        ${CSILK_VERSION}
    )
    FetchContent_MakeAvailable(csilk)
    set(CSILK_LIB csilk)
  endif()
else()
  set(CSILK_LIB csilk::csilk)
endif()

find_package(CURL REQUIRED)
${OPENSSL_FIND}

set(SOURCES
${LAYERED_SOURCES}
)

add_executable(${PROJECT_NAME} \${SOURCES})
target_link_libraries(${PROJECT_NAME} PRIVATE \${CSILK_LIB}\${LINK_DB}${OPENSSL_LINK} \${CURL_LIBRARIES})
target_include_directories(${PROJECT_NAME} PRIVATE
  src
  src/api
  src/service
  src/model
  \${CURL_INCLUDE_DIRS}
)

if(NOT csilk_FOUND)
  include(FetchContent)
  FetchContent_GetProperties(cjson)
  if(cjson_SOURCE_DIR)
    target_include_directories(${PROJECT_NAME} PRIVATE \${cjson_SOURCE_DIR})
  endif()
  FetchContent_GetProperties(llhttp)
  if(llhttp_SOURCE_DIR)
    target_include_directories(${PROJECT_NAME} PRIVATE \${llhttp_SOURCE_DIR}/include)
  endif()
endif()

configure_file(config.yaml \${CMAKE_CURRENT_BINARY_DIR}/config.yaml COPYONLY)
CMAKE
}

generate_model() {
  cat > src/model/user.h <<HDR
#ifndef MODEL_USER_H
#define MODEL_USER_H

#include <stdint.h>
#include <stdbool.h>

typedef struct {
    int32_t id;
    char name[64];
    char email[128];
} user_t;

#undef CSILK_USER_TYPE_MAP
#define CSILK_USER_TYPE_MAP , user_t: "user_t"

#include "csilk/reflection/reflect.h"

#define USER_FIELDS(_) \\
    _(user_t, id, CSILK_TYPE_INT32, 0, 0, false, NULL) \\
    _(user_t, name, CSILK_TYPE_STRING, sizeof(((user_t*)0)->name), 0, false, NULL) \\
    _(user_t, email, CSILK_TYPE_STRING, sizeof(((user_t*)0)->email), 0, false, NULL)

#endif
HDR
  cat > src/model/user.c <<SRC
#include "user.h"
CSILK_REGISTER_REFLECT(user_t, USER_FIELDS)
SRC
}

generate_service() {
  cat > src/service/user_service.h <<HDR
#ifndef SERVICE_USER_SERVICE_H
#define SERVICE_USER_SERVICE_H

#include "user.h"

int user_service_get_all(user_t** users, int* count);
int user_service_create(user_t* user);

#endif
HDR
  cat > src/service/user_service.c <<SRC
#include "user_service.h"
#include <stdlib.h>
#include <string.h>

int user_service_get_all(user_t** users, int* count) {
    *count = 2;
    *users = calloc(*count, sizeof(user_t));
    (*users)[0].id = 1;
    strcpy((*users)[0].name, "Alice");
    strcpy((*users)[0].email, "alice@example.com");
    (*users)[1].id = 2;
    strcpy((*users)[1].name, "Bob");
    strcpy((*users)[1].email, "bob@example.com");
    return 0;
}

int user_service_create(user_t* user) {
    user->id = 123;
    return 0;
}
SRC
}

generate_api() {
  cat > src/api/user_handler.h <<HDR
#ifndef API_USER_HANDLER_H
#define API_USER_HANDLER_H

#include "csilk.h"

void get_users_handler(csilk_ctx_t* c);
void create_user_handler(csilk_ctx_t* c);
void admin_handler(csilk_ctx_t* c);
void ping_handler(csilk_ctx_t* c);

#endif
HDR
  cat > src/api/user_handler.c <<SRC
#include "user.h"
#include "user_handler.h"
#include "user_service.h"
#include <stdlib.h>

void ping_handler(csilk_ctx_t* c) {
    csilk_string(c, 200, "pong");
}

void get_users_handler(csilk_ctx_t* c) {
    user_t* users = NULL;
    int count = 0;
    user_service_get_all(&users, &count);

    cJSON* root = cJSON_CreateArray();
    for (int i = 0; i < count; i++) {
        char* json_str = csilk_marshal(&users[i]);
        if (json_str) {
            cJSON_AddItemToArray(root, cJSON_Parse(json_str));
            free(json_str);
        }
    }
    csilk_json(c, 200, root);
    free(users);
}

void create_user_handler(csilk_ctx_t* c) {
    user_t user = {0};
    const char* body = csilk_get_body(c, NULL);
    if (!body || csilk_unmarshal(body, &user) != 1) {
        csilk_string(c, 400, "Invalid JSON");
        return;
    }
    user_service_create(&user);

    char* json_str = csilk_marshal(&user);
    if (json_str) {
        csilk_json(c, 201, cJSON_Parse(json_str));
        free(json_str);
    } else {
        csilk_string(c, 500, "Internal Error");
    }
}

void admin_handler(csilk_ctx_t* c) {
    csilk_string(c, 200, "Admin Access Granted");
}
SRC
}

generate_ai_handler() {
  cat > src/api/ai_handler.h <<HDR
#ifndef API_AI_HANDLER_H
#define API_AI_HANDLER_H
#include "csilk.h"
void chat_handler(csilk_ctx_t* c);
#endif
HDR
  cat > src/api/ai_handler.c <<SRC
#include "ai_handler.h"
#include <stdlib.h>

void chat_handler(csilk_ctx_t* c) {
    csilk_ai_t* ai = csilk_get(c, "ai");
    csilk_ai_context_t* ctx = csilk_get(c, "ai_ctx");
    if (!ai) {
        csilk_json_error(c, 500, "AI driver not initialized");
        return;
    }

    const char* user_msg = csilk_get_query(c, "msg");
    if (!user_msg) {
        csilk_json_error(c, 400, "Missing 'msg' query parameter");
        return;
    }

    csilk_ai_context_add(ctx, "user", user_msg);

    csilk_ai_chat_request_t req = {
        .model = "gpt-4o",
        .messages = ctx->messages,
        .message_count = ctx->count,
        .temperature = 0.7
    };

    csilk_ai_chat_response_t res = {0};
    if (csilk_ai_chat(ai, &req, &res) == 0) {
        csilk_ai_context_add(ctx, "assistant", res.content);
        csilk_json_error(c, 200, res.content);
        csilk_ai_chat_response_free(&res);
    } else {
        csilk_json_error(c, 500, "AI chat failed");
    }
}
SRC
}

generate_ws_handler() {
  cat > src/api/ws_handler.h <<HDR
#ifndef API_WS_HANDLER_H
#define API_WS_HANDLER_H
#include "csilk.h"
void ws_chat_handler(csilk_ctx_t* c);
#endif
HDR
  cat > src/api/ws_handler.c <<SRC
#include "ws_handler.h"
#include <stdio.h>

static void on_ws_message(csilk_ctx_t* c, const uint8_t* data, size_t len, int binary) {
    csilk_ws_send(c, data, len, binary);
}

void ws_chat_handler(csilk_ctx_t* c) {
    csilk_ws_handshake(c);
    csilk_set_on_ws_message(c, on_ws_message);
}
SRC
}

generate_sse_handler() {
  cat > src/api/sse_handler.h <<HDR
#ifndef API_SSE_HANDLER_H
#define API_SSE_HANDLER_H
#include "csilk.h"
void sse_events_handler(csilk_ctx_t* c);
#endif
HDR
  cat > src/api/sse_handler.c <<SRC
#include "sse_handler.h"
#include <stdio.h>
#include <time.h>

void sse_events_handler(csilk_ctx_t* c) {
    csilk_sse_init(c);
    for (int i = 0; i < 10; i++) {
        char buf[128];
        snprintf(buf, sizeof(buf), "event %d at %ld", i, (long)time(NULL));
        csilk_sse_send(c, "time", buf);
    }
    csilk_sse_close(c);
}
SRC
}

generate_upload_handler() {
  cat > src/api/upload_handler.h <<HDR
#ifndef API_UPLOAD_HANDLER_H
#define API_UPLOAD_HANDLER_H
#include "csilk.h"
void upload_handler(csilk_ctx_t* c);
#endif
HDR
  cat > src/api/upload_handler.c <<SRC
#include "upload_handler.h"
#include <stdio.h>

static void upload_part_cb(csilk_multipart_part_t* part) {
    fprintf(stderr, "Part: name=%s, filename=%s, type=%s, size=%zu\n",
            part->name, part->filename, part->content_type, part->data_len);
}

void upload_handler(csilk_ctx_t* c) {
    csilk_multipart_parse(c, upload_part_cb);
    csilk_string(c, 200, "Upload received");
}
SRC
}

generate_workflow_handler() {
  cat > src/api/workflow_handler.h <<HDR
#ifndef API_WORKFLOW_HANDLER_H
#define API_WORKFLOW_HANDLER_H
#include "csilk.h"
#include "csilk/app/workflow.h"
void workflow_demo_handler(csilk_ctx_t* c);
#endif
HDR
  cat > src/api/workflow_handler.c <<SRC
#include "workflow_handler.h"
#include <stdio.h>
#include <string.h>

static csilk_data_t* greet_handler(csilk_wf_ctx_t* ctx, csilk_data_t* input, void* user_data) {
    const char* name = input && input->value ? (const char*)input->value : "World";
    char* msg = csilk_wf_alloc(ctx, 64);
    snprintf(msg, 64, "Hello, %s!", name);
    return csilk_wf_data_new(ctx, "text/plain", msg);
}

void workflow_demo_handler(csilk_ctx_t* c) {
    csilk_wf_t* wf = csilk_wf_new("demo");
    csilk_wf_node_t* n1 = csilk_wf_add(wf, "greet", greet_handler, NULL);
    csilk_wf_node_set_entry(n1, 1);

    csilk_string(c, 200, "Workflow triggered");
    csilk_wf_free(wf);
}
SRC
}

generate_main() {
  cat > src/main.c <<MAIN
#include <stdlib.h>
#include <string.h>
#include "user.h"
#include "csilk.h"
MAIN
  if [ "$API_STYLE" = "app" ]; then echo '#include "csilk/app/app.h"' >> src/main.c; fi
  if [ -n "$HDR_DB" ]; then echo "$HDR_DB" >> src/main.c; fi
  if [ -n "$PERM_HDR" ]; then echo "$PERM_HDR" >> src/main.c; fi
  if [ -n "$AI_HDR" ]; then echo "$AI_HDR" >> src/main.c; fi
  if [ -n "$CIPHER_HDR" ]; then echo "$CIPHER_HDR" >> src/main.c; fi
  if [ -n "$WS_HDR" ]; then echo "$WS_HDR" >> src/main.c; fi
  if [ -n "$SSE_HDR" ]; then echo "$SSE_HDR" >> src/main.c; fi
  if [ -n "$ADMIN_HDR" ]; then echo "$ADMIN_HDR" >> src/main.c; fi
  if [ -n "$WORKFLOW_HDR" ]; then echo "$WORKFLOW_HDR" >> src/main.c; fi
  if [ -n "$MQ_HDR" ]; then echo "$MQ_HDR" >> src/main.c; fi
  if [ -n "$UPLOAD_HDR" ]; then echo "$UPLOAD_HDR" >> src/main.c; fi
  if [ "$AI_PROVIDER" != "none" ]; then echo '#include "ai_handler.h"' >> src/main.c; fi
  if [ "$USE_WS" = "1" ]; then echo '#include "ws_handler.h"' >> src/main.c; fi
  if [ "$USE_SSE" = "1" ]; then echo '#include "sse_handler.h"' >> src/main.c; fi
  if [ "$USE_UPLOAD" = "1" ]; then echo '#include "upload_handler.h"' >> src/main.c; fi
  if [ "$USE_WORKFLOW" = "1" ]; then echo '#include "workflow_handler.h"' >> src/main.c; fi
  if [ -n "$AI_GLOBALS" ]; then echo -e "\n$AI_GLOBALS" >> src/main.c; fi
  if [ -n "$MQ_GLOBALS" ]; then echo -e "\n$MQ_GLOBALS" >> src/main.c; fi

  cat >> src/main.c <<MAIN
#include "user_handler.h"

MAIN

  # Middleware wrappers
  if [ "$MID_CORS" = "y" ]; then
    cat >> src/main.c <<EOF
static void cors_middleware_wrapper(csilk_ctx_t* c) {
  static const csilk_cors_config_t config = {
    .allow_origin = "*",
    .allow_methods = "GET,POST,PUT,DELETE,OPTIONS",
    .allow_headers = "Content-Type,Authorization",
    .max_age = 86400
  };
  csilk_cors_middleware(c, &config);
}
EOF
  fi
  if [ "$AUTH" = "jwt" ]; then
    cat >> src/main.c <<EOF
static void jwt_middleware_wrapper(csilk_ctx_t* c) {
  csilk_jwt_middleware(c, "your-secret-key");
}
EOF
  fi
  if [ "$AUTH" = "token" ]; then
    cat >> src/main.c <<EOF
static int simple_auth_validator(const char* token) {
  return strcmp(token, "secret123") == 0;
}
static void auth_middleware_wrapper(csilk_ctx_t* c) {
  csilk_auth_middleware(c, simple_auth_validator);
}
EOF
  fi
  if [ "$MID_RATELIMIT" = "y" ]; then
    cat >> src/main.c <<EOF
static void ratelimit_middleware_wrapper(csilk_ctx_t* c) {
  csilk_rate_limit_middleware(c, 100);
}
EOF
  fi
  if [ "$USE_METRICS" = "1" ]; then
    cat >> src/main.c <<EOF
static void csilk_metrics_middleware_wrapper(csilk_ctx_t* c) {
  csilk_metrics_middleware(c, "$PROJECT_NAME");
}
EOF
  fi

  if [ -n "$AI_FUNCS" ]; then echo -e "\n$AI_FUNCS" >> src/main.c; fi
  if [ -n "$MQ_FUNCS" ]; then echo -e "\n$MQ_FUNCS" >> src/main.c; fi
  if [ -n "$HOOKS_FUNCS" ]; then echo -e "\n$HOOKS_FUNCS" >> src/main.c; fi

  if [ "$API_STYLE" = "app" ]; then
    cat >> src/main.c <<MAIN
int main(void) {
MAIN
    if [ -n "$SETUP_DB" ]; then echo "$SETUP_DB" >> src/main.c; fi
    if [ -n "$PERM_INIT" ]; then echo "$PERM_INIT" >> src/main.c; fi

    cat >> src/main.c <<MAIN
  csilk_app_t* app = csilk_app_new("config.yaml");
  if (!app) return 1;

MAIN
    if [ -n "$CIPHER_SETUP" ]; then echo "$CIPHER_SETUP" >> src/main.c; fi
    if [ -n "$AI_SETUP" ]; then echo "$AI_SETUP" >> src/main.c; fi
    if [ -n "$MQ_SETUP" ]; then echo "$MQ_SETUP" >> src/main.c; fi
    if [ -n "$HOOKS_SETUP" ]; then echo "$HOOKS_SETUP" >> src/main.c; fi

    cat >> src/main.c <<MAIN
  /* Middleware */
MAIN
    if [ -n "$AUTH_MID" ]; then echo "$AUTH_MID" >> src/main.c; fi
    if [ -n "$PERM_MID" ]; then echo "$PERM_MID" >> src/main.c; fi
    if [ -n "$CSRF_MID" ]; then echo "$CSRF_MID" >> src/main.c; fi
    if [ -n "$METRICS_MID" ]; then echo "$METRICS_MID" >> src/main.c; fi
    echo -e "$MID_SETUP" >> src/main.c
    if [ -n "$SWAGGER_SETUP" ]; then echo "$SWAGGER_SETUP" >> src/main.c; fi
    if [ -n "$SPA_SETUP" ]; then echo "$SPA_SETUP" >> src/main.c; fi

    if [ -n "$USE_DB_EXEC" ]; then echo "${USE_DB_EXEC}" >> src/main.c; fi

    cat >> src/main.c <<MAIN

  /* Routes */
  csilk_app_get(app, "/health", ping_handler);
MAIN
    if [ -n "$WS_ROUTES" ]; then echo "$WS_ROUTES" >> src/main.c; fi
    if [ -n "$SSE_ROUTES" ]; then echo -e "$SSE_ROUTES" >> src/main.c; fi
    if [ -n "$METRICS_ROUTES" ]; then echo "$METRICS_ROUTES" >> src/main.c; fi
    if [ -n "$UPLOAD_ROUTES" ]; then echo "$UPLOAD_ROUTES" >> src/main.c; fi
    if [ -n "$WORKFLOW_ROUTES" ]; then echo "$WORKFLOW_ROUTES" >> src/main.c; fi

    echo '' >> src/main.c
    echo '  csilk_app_get_ext(app, "/api/users", get_users_handler, NULL, "user_t",' >> src/main.c
    echo '                    "List Users", "Returns a list of all users");' >> src/main.c
    echo '  csilk_app_post_ext(app, "/api/users", create_user_handler, "user_t", "user_t",' >> src/main.c
    echo '                     "Create User", "Creates a new user");' >> src/main.c

    if [ "$AI_PROVIDER" != "none" ]; then
      echo '  csilk_app_get(app, "/api/chat", chat_handler);' >> src/main.c
    fi
    if [ -n "$PERM_ROUTES" ]; then echo "  $PERM_ROUTES" >> src/main.c; fi
    if [ "$USE_SWAGGER" = "1" ]; then
      echo '  csilk_app_get(app, "/", (csilk_handler_t)csilk_serve_swagger_ui);' >> src/main.c
    elif [ "$USE_ADMIN" = "1" ]; then
      echo '  /* Admin registered at /admin */' >> src/main.c
    fi

    cat >> src/main.c <<MAIN

  printf("\n  Service started on port ${PORT}\n");
MAIN
    if [ "$USE_SWAGGER" = "1" ]; then
      echo '  printf("  Swagger UI: http://localhost:'"${PORT}"'/\n");' >> src/main.c
      echo '  printf("  OpenAPI Spec: http://localhost:'"${PORT}"'/openapi.json\n\n");' >> src/main.c
    fi
    if [ "$USE_ADMIN" = "1" ]; then
      echo '  printf("  Admin Dashboard: http://localhost:'"${PORT}"'/admin\n");' >> src/main.c
    fi

    echo '' >> src/main.c
    echo '  int rc = csilk_app_run(app, '"${PORT}"');' >> src/main.c
    if [ -n "$CLEANUP_DB" ]; then echo "$CLEANUP_DB" >> src/main.c; fi
    if [ -n "$AI_CLEANUP" ]; then echo "$AI_CLEANUP" >> src/main.c; fi
    if [ -n "$MQ_CLEANUP" ]; then echo "$MQ_CLEANUP" >> src/main.c; fi
    cat >> src/main.c <<MAIN
  csilk_app_free(app);
  return rc;
}
MAIN
  else
    cat >> src/main.c <<MAIN
int main(void) {
MAIN
    if [ -n "$SETUP_DB" ]; then echo "$SETUP_DB" >> src/main.c; fi
    if [ -n "$PERM_INIT" ]; then echo "$PERM_INIT" >> src/main.c; fi
    cat >> src/main.c <<MAIN
  csilk_router_t* router = csilk_router_new();
  if (!router) return 1;
  csilk_server_t* server = csilk_server_new(router);
  if (!server) { csilk_router_free(router); return 1; }

  csilk_server_use(server, csilk_recovery_handler);
  csilk_server_use(server, csilk_logger_handler);
MAIN
    if [ -n "$PERM_MID" ]; then echo "  csilk_server_use(server, csilk_perm_auto_middleware);" >> src/main.c; fi
    if [ -n "$USE_DB_EXEC" ]; then echo "${USE_DB_EXEC}" >> src/main.c; fi

    cat >> src/main.c <<MAIN
  csilk_router_add(router, "GET", "/health", (csilk_handler_t[]){ping_handler, NULL}, 1);
  csilk_router_add(router, "GET", "/api/users", (csilk_handler_t[]){get_users_handler, NULL}, 1);
MAIN
    if [ -n "$PERM_ROUTES" ]; then echo "  csilk_router_add_perm(router, \"GET\", \"/admin\", (csilk_handler_t[]){admin_handler, NULL}, 1, \"admin\", \"*\");" >> src/main.c; fi

    cat >> src/main.c <<MAIN
  csilk_server_run(server, ${PORT});
MAIN
    if [ -n "$CLEANUP_DB" ]; then echo "$CLEANUP_DB" >> src/main.c; fi
    cat >> src/main.c <<MAIN
  csilk_server_free(server);
  csilk_router_free(router);
  return 0;
}
MAIN
  fi
}

generate_readme() {
  cat > README.md <<README
# ${PROJECT_NAME}

Generated with [csilk](${CSILK_REPO_DEFAULT}) v${CSILK_VERSION}.

## Architecture

- \`src/api/\`: Handlers and route definitions.
- \`src/service/\`: Business logic layer.
- \`src/model/\`: Data structures and reflection metadata.

## Quick start

\`\`\`bash
mkdir build && cd build
cmake ..
make
./${PROJECT_NAME}
\`\`\`

## Endpoints

| Method | Path | Description |
|--------|------|-------------|
| GET | /health | Health check |
| GET | /api/users | List all users |
| POST | /api/users | Create a new user |
README
  if [ "$USE_SWAGGER" = "1" ]; then
    cat >> README.md <<README
| GET | / | Swagger UI |
| GET | /openapi.json | OpenAPI spec |
README
  fi
  if [ "$USE_WS" = "1" ]; then
    cat >> README.md <<README
| GET | /ws | WebSocket endpoint |
README
  fi
  if [ "$USE_SSE" = "1" ]; then
    cat >> README.md <<README
| GET | /events | SSE event stream |
README
  fi
  if [ "$USE_ADMIN" = "1" ]; then
    cat >> README.md <<README
| GET | /admin | Admin dashboard |
README
  fi
  if [ "$USE_METRICS" = "1" ]; then
    cat >> README.md <<README
| GET | /metrics | Prometheus metrics |
README
  fi
  if [ "$USE_UPLOAD" = "1" ]; then
    cat >> README.md <<README
| POST | /upload | File upload |
README
  fi
  if [ "$USE_WORKFLOW" = "1" ]; then
    cat >> README.md <<README
| GET | /workflow | Workflow UI |
README
  fi
  if [ "$AI_PROVIDER" != "none" ]; then
    cat >> README.md <<README
| GET | /api/chat | AI Chat |
README
  fi
}

# ── Main Execution ──
print_banner
log_step "csilk Project Scaffolding"

PROJECT_NAME=""; OUT_DIR=""; PORT=""; API_STYLE=""; DB=""; AI_PROVIDER=""
USE_CIPHER=""; AUTH=""; USE_PERM=""; USE_SWAGGER=""
MID_CORS="n"; MID_GZIP="n"; MID_RATELIMIT="n"; MID_SESSION="n"; MID_REQUESTID="n"; MID_CSRF="n"
USE_WS=""; USE_SSE=""; USE_ADMIN=""; USE_WORKFLOW=""; USE_METRICS=""
USE_UPLOAD=""; USE_SPA=""; USE_HOOKS=""; USE_MQ=""
DO_GIT=""; NON_INTERACTIVE=0

while [[ "$#" -gt 0 ]]; do
  case $1 in
    -h|--help) show_help; exit 0 ;;
    -n|--name) PROJECT_NAME="$2"; shift ;;
    -o|--out-dir) OUT_DIR="$2"; shift ;;
    -p|--port) PORT="$2"; shift ;;
    --api-style) API_STYLE="$2"; shift ;;
    --db) DB="$2"; shift ;;
    --ai) AI_PROVIDER="$2"; shift ;;
    --cipher) USE_CIPHER="1" ;;
    --auth) AUTH="$2"; shift ;;
    --use-perm) USE_PERM="1" ;;
    --use-swagger) USE_SWAGGER="1" ;;
    --use-ws) USE_WS="1" ;;
    --use-sse) USE_SSE="1" ;;
    --use-admin) USE_ADMIN="1" ;;
    --use-workflow) USE_WORKFLOW="1" ;;
    --use-metrics) USE_METRICS="1" ;;
    --use-upload) USE_UPLOAD="1" ;;
    --use-spa) USE_SPA="1" ;;
    --use-hooks) USE_HOOKS="1" ;;
    --use-mq) USE_MQ="1" ;;
    --middleware)
      IFS=',' read -r -a mids <<< "$2"
      for m in "${mids[@]}"; do
        m="${m// /}"
        case "$m" in
          cors) MID_CORS="y" ;;
          gzip) MID_GZIP="y" ;;
          ratelimit) MID_RATELIMIT="y" ;;
          session) MID_SESSION="y" ;;
          requestid) MID_REQUESTID="y" ;;
          csrf) MID_CSRF="y" ;;
        esac
      done
      shift ;;
    --git) DO_GIT="1" ;;
    --non-interactive) NON_INTERACTIVE=1 ;;
    *) log_error "Unknown parameter: $1"; exit 1 ;;
  esac
  shift
done

# Interactive prompts
if [ -z "$PROJECT_NAME" ]; then
  if [ "$NON_INTERACTIVE" -eq 1 ]; then PROJECT_NAME="myapp"; else PROJECT_NAME=$(ask "Project name" "myapp"); fi
fi
DIR_NAME="${PROJECT_NAME// /-}"; DIR_NAME="${DIR_NAME,,}"

if [ -z "$OUT_DIR" ]; then
  if [ "$NON_INTERACTIVE" -eq 1 ]; then OUT_DIR="./$DIR_NAME"; else OUT_DIR=$(ask "Output directory" "./$DIR_NAME"); fi
fi
if [ -z "$PORT" ]; then
  if [ "$NON_INTERACTIVE" -eq 1 ]; then PORT="8080"; else PORT=$(ask "Port number" "8080"); fi
fi
if [ -z "$API_STYLE" ]; then
  if [ "$NON_INTERACTIVE" -eq 1 ]; then API_STYLE="app"; else
    API_STYLE=$(pick "API style:" "app" 'app|High-level convenience API (csilk_app_t)
core|Low-level core API (csilk_router_t + csilk_server_t)')
  fi
fi
if [ -z "$DB" ]; then
  if [ "$NON_INTERACTIVE" -eq 1 ]; then DB="sqlite"; else
    DB=$(pick "Database backend:" "sqlite" 'sqlite|SQLite (built-in)
mysql|MySQL (requires libmysqlclient)
postgres|PostgreSQL (requires libpq)
none|No database')
  fi
fi
if [ -z "$AI_PROVIDER" ]; then
  if [ "$NON_INTERACTIVE" -eq 1 ]; then AI_PROVIDER="none"; else
    AI_PROVIDER=$(pick "AI provider:" "none" 'none|No AI support
openai|OpenAI
ollama|Ollama (local)')
  fi
fi
if [ -z "$USE_CIPHER" ]; then
  if [ "$NON_INTERACTIVE" -eq 1 ]; then USE_CIPHER="0"; else
    USE_CIPHER=$(ask_yes "Enable OpenSSL cipher driver" "n" && echo "1" || echo "0")
  fi
fi
if [ -z "$AUTH" ]; then
  if [ "$NON_INTERACTIVE" -eq 1 ]; then AUTH="none"; else
    AUTH=$(pick "Authentication:" "none" 'none|No authentication
jwt|JWT-based authentication
token|Bearer token (simple validator callback)')
  fi
fi
if [ -z "$USE_PERM" ]; then
  if [ "$NON_INTERACTIVE" -eq 1 ]; then USE_PERM="0"; else
    USE_PERM=$(ask_yes "Enable permission system" "n" && echo "1" || echo "0")
  fi
fi
if [ -z "$USE_SWAGGER" ]; then
  if [ "$NON_INTERACTIVE" -eq 1 ]; then USE_SWAGGER="1"; else
    USE_SWAGGER=$(ask_yes "Enable Swagger/OpenAPI" "y" && echo "1" || echo "0")
  fi
fi

# Extra features interactive prompts
if [ "$NON_INTERACTIVE" -eq 0 ]; then
  if [ -z "$USE_WS" ]; then USE_WS=$(ask_yes "WebSocket chat endpoint" "n" && echo "1" || echo "0"); fi
  if [ -z "$USE_SSE" ]; then USE_SSE=$(ask_yes "SSE event stream endpoint" "n" && echo "1" || echo "0"); fi
  if [ -z "$USE_ADMIN" ]; then USE_ADMIN=$(ask_yes "Admin dashboard (/admin)" "n" && echo "1" || echo "0"); fi
  if [ -z "$USE_METRICS" ]; then USE_METRICS=$(ask_yes "Prometheus metrics (/metrics)" "n" && echo "1" || echo "0"); fi
  if [ -z "$USE_UPLOAD" ]; then USE_UPLOAD=$(ask_yes "Multipart file upload" "n" && echo "1" || echo "0"); fi
  if [ -z "$USE_SPA" ]; then USE_SPA=$(ask_yes "SPA fallback (serve index.html)" "n" && echo "1" || echo "0"); fi
  if [ -z "$USE_HOOKS" ]; then USE_HOOKS=$(ask_yes "Server lifecycle hooks" "n" && echo "1" || echo "0"); fi
  if [ -z "$USE_MQ" ]; then USE_MQ=$(ask_yes "Message Queue" "n" && echo "1" || echo "0"); fi
  if [ -z "$USE_WORKFLOW" ]; then USE_WORKFLOW=$(ask_yes "AI Workflow engine" "n" && echo "1" || echo "0"); fi
fi

# Defaults for non-interactive
[ -z "$USE_WS" ] && USE_WS="0"
[ -z "$USE_SSE" ] && USE_SSE="0"
[ -z "$USE_ADMIN" ] && USE_ADMIN="0"
[ -z "$USE_WORKFLOW" ] && USE_WORKFLOW="0"
[ -z "$USE_METRICS" ] && USE_METRICS="0"
[ -z "$USE_UPLOAD" ] && USE_UPLOAD="0"
[ -z "$USE_SPA" ] && USE_SPA="0"
[ -z "$USE_HOOKS" ] && USE_HOOKS="0"
[ -z "$USE_MQ" ] && USE_MQ="0"

# Extra middleware interactive (only if none set yet)
if [ "$NON_INTERACTIVE" -eq 0 ] && [ "$MID_CORS" = "n" ] && [ "$MID_GZIP" = "n" ] && [ "$MID_RATELIMIT" = "n" ] && [ "$MID_SESSION" = "n" ] && [ "$MID_REQUESTID" = "n" ] && [ "$MID_CSRF" = "n" ]; then
  echo -e "  ${BOLD}Extra middleware${NC} (comma-separated, e.g. cors,gzip):"
  printf "    cors, gzip, ratelimit, session, requestid, csrf\n" >&2
  printf "  choices [none]: " >&2
  IFS=',' read -r -a mid_choices
  for m in "${mid_choices[@]}"; do
    m="${m// /}"
    case "$m" in
      cors) MID_CORS="y" ;;
      gzip) MID_GZIP="y" ;;
      ratelimit) MID_RATELIMIT="y" ;;
      session) MID_SESSION="y" ;;
      requestid) MID_REQUESTID="y" ;;
      csrf) MID_CSRF="y" ;;
      none|"") ;;
    esac
  done
fi

if [ -z "$DO_GIT" ]; then
  if [ "$NON_INTERACTIVE" -eq 1 ]; then DO_GIT="1"; else
    DO_GIT=$(ask_yes "Initialize git repository" "y" && echo "1" || echo "0")
  fi
fi

# Validation
validate_inputs
prepare_vars

log_step "Creating project files in $OUT_DIR..."

mkdir -p "$OUT_DIR/src/api"
mkdir -p "$OUT_DIR/src/service"
mkdir -p "$OUT_DIR/src/model"
mkdir -p "$OUT_DIR/public"
touch "$OUT_DIR/public/.gitkeep"

cd "$OUT_DIR"
generate_gitignore
generate_config
generate_cmake
generate_model
generate_service
generate_api

if [ "$AI_PROVIDER" != "none" ]; then generate_ai_handler; fi
if [ "$USE_WS" = "1" ]; then generate_ws_handler; fi
if [ "$USE_SSE" = "1" ]; then generate_sse_handler; fi
if [ "$USE_UPLOAD" = "1" ]; then generate_upload_handler; fi
if [ "$USE_WORKFLOW" = "1" ]; then generate_workflow_handler; fi

generate_main
generate_readme

if [ "$DO_GIT" = "1" ]; then
  if command -v git >/dev/null 2>&1; then
    git init -q
    git add -A
    git commit -m "initial commit from csilkskel" -q || true
    log_success "Git repository initialized."
  else
    log_warn "git command not found, skipping initialization."
  fi
fi

log_success "Project '$PROJECT_NAME' created successfully!"
echo -e "\n  To build and run:"
echo -e "    ${BLUE}cd ${OUT_DIR}${NC}"
echo -e "    ${BLUE}mkdir build && cd build${NC}"
echo -e "    ${BLUE}cmake ..${NC}  (or ${BLUE}cmake .. -DCSILK_SOURCE_DIR=/path/to/csilk${NC})"
echo -e "    ${BLUE}make && ./${PROJECT_NAME}${NC}\n"
