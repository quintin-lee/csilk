#!/bin/bash
set -e

CSILK_VERSION="f1950d5"
AI_PROVIDER="none"
USE_CIPHER="0"
MID_REQUESTID="n"

# Auto-detect repo URL from the local csilk checkout (if script is run from within the repo)
LOCAL_REMOTE=$(git config --get remote.origin.url 2>/dev/null || true)
if echo "$LOCAL_REMOTE" | grep -qE 'github\.com[/:](.+)/(.+)\.git'; then
  LOCAL_REPO_PATH=$(echo "$LOCAL_REMOTE" | sed -E 's|.*github\.com[/:](.+)/(.+)\.git|\1/\2|')
  CSILK_REPO_DEFAULT="https://github.com/${LOCAL_REPO_PATH}.git"
else
  CSILK_REPO_DEFAULT="https://github.com/quintin-lee/csilk.git"
fi

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m' # No Color

log_info() { echo -e "${BLUE}[INFO]${NC} $1" >&2; }
log_success() { echo -e "${GREEN}[SUCCESS]${NC} $1" >&2; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1" >&2; }
log_error() { echo -e "${RED}[ERROR]${NC} $1" >&2; }
log_step() { echo -e "\n${BLUE}==>${NC} ${BOLD}${1}${NC}" >&2; }

print_banner() {
  cat <<'EOF'
╔══════════════════════════════════════════╗
║           csilk scaffold tool            ║
║     Generate a new csilk project         ║
╚══════════════════════════════════════════╝
EOF
}

ask() {
  local prompt="$1" default="$2" var
  printf "  ${BOLD}%s${NC} [%s]: " "$prompt" "$default" >&2
  read -r var
  echo "${var:-$default}"
}

ask_yes() {
  local prompt="$1" default="$2" ans
  printf "  ${BOLD}%s${NC} [%s]: " "$prompt" "$default" >&2
  read -r ans
  ans="${ans:-$default}"
  case "$ans" in
    [Yy]*) return 0 ;;
    *) return 1 ;;
  esac
}

pick() {
  local prompt="$1" default="$2" desc="$3"
  echo -e "  ${BOLD}${prompt}${NC}" >&2
  echo "$desc" | while IFS='|' read -r key label; do
    if [ -n "$key" ]; then printf "    ${BLUE}%s)${NC} %s\n" "$key" "$label" >&2; fi
  done
  printf "  choice [%s]: " "$default" >&2
  read -r ans
  echo "${ans:-$default}"
}

show_help() {
  cat <<EOF
Usage: csilkskel [options]

Options:
-h, --help            Show this help message
-n, --name NAME       Project name (default: myapp)
-o, --out-dir DIR     Output directory (default: ./<name>)
-p, --port PORT       Port number (default: 8080)
--api-style STYLE     API style: app, core (default: app)
--db DB               Database: sqlite, mysql, postgres, none (default: sqlite)
--ai PROVIDER         AI driver: none, openai, ollama (default: none)
--cipher              Enable OpenSSL cipher driver
--auth AUTH           Auth: none, jwt, token (default: none)
--use-perm            Enable permission system
--use-swagger         Enable Swagger/OpenAPI
--middleware LIST     Comma-separated list (cors,gzip,ratelimit,session,requestid)
--git                 Initialize git repository
--non-interactive     Skip prompts and use defaults for missing values

Example:
csilkskel -n myapp -p 9090 --db mysql --ai openai --cipher --middleware cors,gzip,requestid --git
EOF
}

validate_inputs() {
  if [[ ! "$PROJECT_NAME" =~ ^[a-zA-Z_][a-zA-Z0-9_]*$ ]]; then
    log_error "Project name must be a valid C identifier (letters, numbers, underscores, starting with letter/underscore)."
    exit 1
  fi
  if ! [[ "$PORT" =~ ^[0-9]+$ ]] || [ "$PORT" -lt 1 ] || [ "$PORT" -gt 65535 ]; then
    log_error "Port must be a number between 1 and 65535."
    exit 1
  fi
  if [ -d "$OUT_DIR" ] && [ "$(ls -A "$OUT_DIR" 2>/dev/null)" ]; then
    log_warn "Output directory '$OUT_DIR' already exists and is not empty."
    if [ "$NON_INTERACTIVE" -eq 1 ]; then
      log_error "Aborting due to non-interactive mode."
      exit 1
    fi
    if ! ask_yes "Continue anyway and potentially overwrite files?" "n"; then
      exit 1
    fi
  fi
}

prepare_vars() {
  # ──────────────────────────────────────────────
  # CMake & Source variables based on choices
  # ──────────────────────────────────────────────
  BUILD_DB=""; LINK_DB=""; HDR_DB=""; SETUP_DB=""; CLEANUP_DB=""; USE_DB_EXEC=""

  if [ "$DB" = "mysql" ]; then
    BUILD_DB='find_library(MYSQL_LIB NAMES mysqlclient libmysqlclient)
if(NOT MYSQL_LIB)
  message(FATAL_ERROR "libmysqlclient not found")
endif()
find_path(MYSQL_INCLUDE_DIR mysql.h PATHS /usr/include/mysql /usr/local/include/mysql)
if(MYSQL_INCLUDE_DIR)
  include_directories(${MYSQL_INCLUDE_DIR})
endif()'
    LINK_DB=' ${MYSQL_LIB}'
    HDR_DB='#include "csilk_db.h"'
    SETUP_DB='  csilk_db_init();'
    CLEANUP_DB='  if (pool) csilk_db_pool_free(pool);'
    USE_DB_EXEC='  csilk_db_pool_t* pool = csilk_db_pool_new("mysql", "host=127.0.0.1;port=3306;user=root;password=secret;dbname='"${PROJECT_NAME}"'");'
  elif [ "$DB" = "postgres" ]; then
    BUILD_DB='find_library(PQ_LIB NAMES pq libpq)
if(NOT PQ_LIB)
  message(FATAL_ERROR "libpq not found")
endif()'
    LINK_DB=' ${PQ_LIB}'
    HDR_DB='#include "csilk_db.h"'
    SETUP_DB='  csilk_db_init();'
    CLEANUP_DB='  if (pool) csilk_db_pool_free(pool);'
    USE_DB_EXEC='  csilk_db_pool_t* pool = csilk_db_pool_new("postgres", "host=127.0.0.1 port=5432 user=postgres password=secret dbname='"${PROJECT_NAME}"'");'
  elif [ "$DB" = "sqlite" ]; then
    BUILD_DB=''
    LINK_DB=''
    HDR_DB='#include "csilk_db.h"'
    SETUP_DB='  csilk_db_init();'
    CLEANUP_DB='  if (pool) csilk_db_pool_free(pool);'
    USE_DB_EXEC='  csilk_db_pool_t* pool = csilk_db_pool_new("sqlite", "'"${PROJECT_NAME}"'.db");'
  fi

  AUTH_HDR=""; AUTH_SETUP=""; AUTH_MID=""
  if [ "$AUTH" = "jwt" ]; then
    AUTH_MID='  csilk_app_use(app, jwt_middleware_wrapper);'
  elif [ "$AUTH" = "token" ]; then
    AUTH_MID='  csilk_app_use(app, auth_middleware_wrapper);'
  fi

  PERM_HDR=""; PERM_INIT=""; PERM_MID=""; PERM_ROUTES=""; PERM_RULES=""
  if [ "$USE_PERM" = "1" ]; then
    PERM_HDR='#include "csilk_perm.h"'
    PERM_INIT='  csilk_perm_init();
  csilk_perm_simple_allow("admin", "*", "*");
  csilk_perm_simple_allow("user", "read", "*");
  csilk_perm_set_default("simple");'
    PERM_MID='  csilk_app_use(app, csilk_perm_auto_middleware);'
    PERM_ROUTES='csilk_app_get_perm(app, "/admin", admin_handler, "admin", "*");'
    PERM_RULES='csilk_perm_simple_allow("admin", "*", "*");'
  fi

  SWAGGER_SETUP=""
  if [ "$USE_SWAGGER" = "1" ]; then
    SWAGGER_SETUP='  csilk_app_enable_openapi(app, 1);'
  fi

  AI_HDR=""; AI_SETUP=""; AI_CLEANUP=""
  if [ "$AI_PROVIDER" != "none" ]; then
    AI_HDR='#include "csilk/drivers/ai.h"'
    AI_SETUP='  csilk_ai_t* ai = csilk_ai_new(config->ai.driver, config->ai.api_key, config->ai.base_url);
  csilk_ai_context_t* ai_ctx = csilk_ai_context_new(10);
  csilk_set(app, "ai", ai);
  csilk_set(app, "ai_ctx", ai_ctx);'
    AI_CLEANUP='  csilk_ai_free(ai);
  csilk_ai_context_free(ai_ctx);'
    LAYERED_SOURCES="${LAYERED_SOURCES}\n  src/api/ai_handler.c"
  fi

  CIPHER_HDR=""; CIPHER_SETUP=""
  if [ "$USE_CIPHER" = "1" ]; then
    CIPHER_HDR='#include "csilk/drivers/cipher.h"'
    CIPHER_SETUP='  extern csilk_cipher_driver_t openssl_cipher_driver;
  csilk_server_set_cipher_driver(csilk_app_server(app), &openssl_cipher_driver);'
  fi

  MID_SETUP=""
  if [ "$MID_CORS" = "y" ]; then MID_SETUP="${MID_SETUP}  csilk_app_use(app, cors_middleware_wrapper);\n"; fi
  if [ "$MID_GZIP" = "y" ]; then MID_SETUP="${MID_SETUP}  csilk_app_use(app, csilk_gzip_middleware);\n"; fi
  if [ "$MID_RATELIMIT" = "y" ]; then MID_SETUP="${MID_SETUP}  csilk_app_use(app, ratelimit_middleware_wrapper);\n"; fi
  if [ "$MID_SESSION" = "y" ]; then MID_SETUP="${MID_SETUP}  csilk_app_use(app, csilk_session_start);\n"; fi
  if [ "$MID_REQUESTID" = "y" ]; then MID_SETUP="${MID_SETUP}  csilk_app_use(app, csilk_request_id_middleware);\n"; fi

  # Layered Sources
  LAYERED_SOURCES="  src/main.c
  src/api/user_handler.c
  src/service/user_service.c
  src/model/user.c"
}

generate_gitignore() {
  cat > .gitignore <<GITIGNORE
build/
bin/
lib/
*.o
*.so
*.a
compile_commands.json
.cache/
.vscode/
.idea/
.clangd/
*.db
GITIGNORE
}

generate_config() {
  cat > config.yaml <<YAML
port: ${PORT}
server:
  idle_timeout_ms: 5000
  read_timeout_ms: 30000
  write_timeout_ms: 30000
  max_body_size: 1048576
  max_header_size: 65536
  max_url_size: 8192
  max_headers_count: 100
  max_connections: 0
  listen_backlog: 128
  tcp_nodelay: 1
  worker_threads: 4
logger:
  level: DEBUG
middleware:
  enable_logger: 1
  enable_recovery: 1
  enable_request_id: $([ "$MID_REQUESTID" = "y" ] && echo "1" || echo "0")
YAML

  if [ "$AI_PROVIDER" != "none" ]; then
    cat >> config.yaml <<YAML
ai:
  driver: ${AI_PROVIDER}
  model: $([ "$AI_PROVIDER" = "openai" ] && echo "gpt-4o" || echo "llama3")
  api_key: "\${$(echo ${AI_PROVIDER} | tr '[:lower:]' '[:upper:]')_API_KEY}"
  base_url: ""
YAML
  fi

  if [ "$DB" = "sqlite" ]; then
    cat >> config.yaml <<YAML
db:
  driver: sqlite
  dsn: ${PROJECT_NAME}.db
YAML
  fi
}

generate_cmake() {
  cat > CMakeLists.txt <<CMAKE
cmake_minimum_required(VERSION 3.11)
project(${PROJECT_NAME} C)

set(CMAKE_C_STANDARD 11)
set(CMAKE_EXPORT_COMPILE_COMMANDS ON)

# ── find or fetch csilk ──
find_package(csilk QUIET
  HINTS \${CSILK_DIR} /usr/local /usr
  PATH_SUFFIXES lib/cmake/csilk
)

if(NOT csilk_FOUND)
  if(CSILK_SOURCE_DIR)
    # Local subdirectory logic
    set(_csilk_deps_dir "\${CSILK_SOURCE_DIR}/build/_deps")
    if(EXISTS "\${_csilk_deps_dir}/libuv-src/CMakeLists.txt")
      set(FETCHCONTENT_SOURCE_DIR_LIBUV "\${_csilk_deps_dir}/libuv-src" CACHE PATH "" FORCE)
    endif()
    if(EXISTS "\${_csilk_deps_dir}/cjson-src/CMakeLists.txt")
      set(FETCHCONTENT_SOURCE_DIR_CJSON "\${_csilk_deps_dir}/cjson-src" CACHE PATH "" FORCE)
    endif()
    add_subdirectory(\${CSILK_SOURCE_DIR} \${CMAKE_BINARY_DIR}/csilk)
    set(CSILK_LIB csilk)
  else()
    # FetchContent logic
    include(FetchContent)
    FetchContent_Declare(csilk
      GIT_REPOSITORY ${CSILK_REPO_DEFAULT}
      GIT_TAG        ${CSILK_VERSION}
    )
    FetchContent_MakeAvailable(csilk)
    set(CSILK_LIB csilk)
  endif()
endif()

# ── find CURL ──
find_package(CURL REQUIRED)

# ── sources ──
set(SOURCES
${LAYERED_SOURCES}
)

# ── executable ──
add_executable(${PROJECT_NAME} \${SOURCES})
target_link_libraries(${PROJECT_NAME} PRIVATE \${CSILK_LIB}\${LINK_DB} \${CURL_LIBRARIES})
target_include_directories(${PROJECT_NAME} PRIVATE 
  src
  src/api
  src/service
  src/model
  \${CURL_INCLUDE_DIRS}
)

# ── handle dependencies include paths ──
# When building from source (FetchContent or add_subdirectory),
# we must ensure the main project can find dependency headers.
if(NOT csilk_FOUND)
  include(FetchContent)
  FetchContent_GetProperties(cjson)
  if(cjson_SOURCE_DIR)
    target_include_directories(${PROJECT_NAME} PRIVATE \${cjson_SOURCE_DIR})
  endif()
  FetchContent_GetProperties(llhttp)
  if(llhttp_SOURCE_DIR)
    target_include_directories(${PROJECT_NAME} PRIVATE \${llhttp_SOURCE_DIR}/include)
  endif()
endif()

# ── copy config to build dir ──
configure_file(config.yaml \${CMAKE_CURRENT_BINARY_DIR}/config.yaml COPYONLY)
CMAKE
}

generate_model() {
  cat > src/model/user.h <<HDR
#ifndef MODEL_USER_H
#define MODEL_USER_H

#include <stdint.h>
#include <stdbool.h>

typedef struct {
    int32_t id;
    char name[64];
    char email[128];
} user_t;

/* Map user_t to "user_t" string for reflection auto-dispatch.
   Must be defined before including csilk_reflect.h/csilk.h */
#undef CSILK_USER_TYPE_MAP
#define CSILK_USER_TYPE_MAP , user_t: "user_t"

#include "csilk_reflect.h"

#define USER_FIELDS(_) \\
    _(user_t, id, CSILK_TYPE_INT32, 0, 0, false, NULL) \\
    _(user_t, name, CSILK_TYPE_STRING, sizeof(((user_t*)0)->name), 0, false, NULL) \\
    _(user_t, email, CSILK_TYPE_STRING, sizeof(((user_t*)0)->email), 0, false, NULL)

#endif
HDR

  cat > src/model/user.c <<SRC
#include "user.h"

CSILK_REGISTER_REFLECT(user_t, USER_FIELDS)
SRC
}

generate_service() {
  cat > src/service/user_service.h <<HDR
#ifndef SERVICE_USER_SERVICE_H
#define SERVICE_USER_SERVICE_H

#include "user.h"

int user_service_get_all(user_t** users, int* count);
int user_service_create(user_t* user);

#endif
HDR

  cat > src/service/user_service.c <<SRC
#include "user_service.h"
#include <stdlib.h>
#include <string.h>

int user_service_get_all(user_t** users, int* count) {
    *count = 2;
    *users = calloc(*count, sizeof(user_t));
    (*users)[0].id = 1;
    strcpy((*users)[0].name, "Alice");
    strcpy((*users)[0].email, "alice@example.com");
    
    (*users)[1].id = 2;
    strcpy((*users)[1].name, "Bob");
    strcpy((*users)[1].email, "bob@example.com");
    return 0;
}

int user_service_create(user_t* user) {
    user->id = 123; // mock ID assignment
    return 0;
}
SRC
}

generate_api() {
  cat > src/api/user_handler.h <<HDR
#ifndef API_USER_HANDLER_H
#define API_USER_HANDLER_H

#include "csilk.h"

void get_users_handler(csilk_ctx_t* c);
void create_user_handler(csilk_ctx_t* c);
void admin_handler(csilk_ctx_t* c);
void ping_handler(csilk_ctx_t* c);

#endif
HDR

  cat > src/api/user_handler.c <<SRC
#include "user.h"
#include "user_handler.h"
#include "user_service.h"
#include <stdlib.h>

void ping_handler(csilk_ctx_t* c) {
    csilk_string(c, 200, "pong");
}

void get_users_handler(csilk_ctx_t* c) {
    user_t* users = NULL;
    int count = 0;
    user_service_get_all(&users, &count);

    cJSON* root = cJSON_CreateArray();
    for (int i = 0; i < count; i++) {
        char* json_str = csilk_marshal(&users[i]);
        if (json_str) {
            cJSON_AddItemToArray(root, cJSON_Parse(json_str));
            free(json_str);
        }
    }
    
    csilk_json(c, 200, root);
    free(users);
}

void create_user_handler(csilk_ctx_t* c) {
    user_t user = {0};
    const char* body = csilk_get_body(c, NULL);
    if (!body || csilk_unmarshal(body, &user) != 1) {
        csilk_string(c, 400, "Invalid JSON");
        return;
    }

    user_service_create(&user);
    
    char* json_str = csilk_marshal(&user);
    if (json_str) {
        csilk_json(c, 201, cJSON_Parse(json_str));
        free(json_str);
    } else {
        csilk_string(c, 500, "Internal Error");
    }
}

void admin_handler(csilk_ctx_t* c) {
    csilk_string(c, 200, "Admin Access Granted");
}
SRC
}

generate_main() {
  cat > src/main.c <<MAIN
#include "user.h"
#include "csilk.h"
MAIN

  if [ "$API_STYLE" = "app" ]; then
    echo '#include "csilk_app.h"' >> src/main.c
  fi

  if [ -n "$HDR_DB" ]; then echo "$HDR_DB" >> src/main.c; fi
  if [ -n "$PERM_HDR" ]; then echo "$PERM_HDR" >> src/main.c; fi
  
  cat >> src/main.c <<MAIN
#include "user_handler.h"

MAIN

  if [ "$MID_CORS" = "y" ]; then
    cat >> src/main.c <<EOF
static void cors_middleware_wrapper(csilk_ctx_t* c) {
  static const csilk_cors_config_t config = {
    .allow_origin = "*",
    .allow_methods = "GET,POST,PUT,DELETE,OPTIONS",
    .allow_headers = "Content-Type,Authorization",
    .max_age = 86400
  };
  csilk_cors_middleware(c, &config);
}
EOF
  fi

  if [ "$AUTH" = "jwt" ]; then
    cat >> src/main.c <<EOF
static void jwt_middleware_wrapper(csilk_ctx_t* c) {
  csilk_jwt_middleware(c, "your-secret-key");
}
EOF
  fi

  if [ "$AUTH" = "token" ]; then
    cat >> src/main.c <<EOF
static int simple_auth_validator(const char* token) {
  return strcmp(token, "secret123") == 0;
}

static void auth_middleware_wrapper(csilk_ctx_t* c) {
  csilk_auth_middleware(c, simple_auth_validator);
}
EOF
  fi

  if [ "$MID_RATELIMIT" = "y" ]; then
    cat >> src/main.c <<EOF
static void ratelimit_middleware_wrapper(csilk_ctx_t* c) {
  csilk_rate_limit_middleware(c, 100); // 100 requests per window
}
EOF
  fi

  if [ "$API_STYLE" = "app" ]; then
    cat >> src/main.c <<MAIN
int main(void) {
MAIN
    if [ -n "$SETUP_DB" ]; then echo "$SETUP_DB" >> src/main.c; fi
    if [ -n "$PERM_INIT" ]; then echo "$PERM_INIT" >> src/main.c; fi

    cat >> src/main.c <<MAIN
  csilk_app_t* app = csilk_app_new("config.yaml");
  if (!app) return 1;

  /* App-specific middleware */
MAIN

    if [ -n "$AUTH_MID" ]; then echo "$AUTH_MID" >> src/main.c; fi
    if [ -n "$PERM_MID" ]; then echo "$PERM_MID" >> src/main.c; fi
    echo -e "$MID_SETUP" >> src/main.c
    
    if [ -n "$USE_DB_EXEC" ]; then
      echo "${USE_DB_EXEC}" >> src/main.c
    fi

    cat >> src/main.c <<MAIN

  /* Root redirect to Swagger UI */
  csilk_app_get(app, "/", (csilk_handler_t)csilk_serve_swagger_ui);
  csilk_app_get(app, "/health", ping_handler);

  /* API Routes with OpenAPI metadata */
  csilk_app_get_ext(app, "/api/users", get_users_handler, NULL, "user_t", 
                    "List Users", "Returns a list of all users");
  
  csilk_app_post_ext(app, "/api/users", create_user_handler, "user_t", "user_t",
                     "Create User", "Creates a new user");

MAIN
    if [ -n "$PERM_ROUTES" ]; then echo "  $PERM_ROUTES" >> src/main.c; fi

    cat >> src/main.c <<MAIN

  printf("\n  Service started on port ${PORT}\n");
  printf("  Swagger UI: http://localhost:${PORT}/\n");
  printf("  OpenAPI Spec: http://localhost:${PORT}/openapi.json\n\n");

  int rc = csilk_app_run(app, ${PORT});
MAIN
    if [ -n "$CLEANUP_DB" ]; then echo "$CLEANUP_DB" >> src/main.c; fi
    cat >> src/main.c <<MAIN
  csilk_app_free(app);
  return rc;
}
MAIN
  else
    # Core API
    cat >> src/main.c <<MAIN
int main(void) {
MAIN
    if [ -n "$SETUP_DB" ]; then echo "$SETUP_DB" >> src/main.c; fi
    if [ -n "$PERM_INIT" ]; then echo "$PERM_INIT" >> src/main.c; fi

    cat >> src/main.c <<MAIN
  csilk_router_t* router = csilk_router_new();
  if (!router) return 1;

  csilk_server_t* server = csilk_server_new(router);
  if (!server) { csilk_router_free(router); return 1; }

  csilk_server_use(server, csilk_recovery_handler);
  csilk_server_use(server, csilk_logger_handler);
MAIN
    if [ -n "$PERM_MID" ]; then echo "  csilk_server_use(server, csilk_perm_auto_middleware_passthrough);" >> src/main.c; fi
    if [ -n "$USE_DB_EXEC" ]; then echo "${USE_DB_EXEC}" >> src/main.c; fi

    cat >> src/main.c <<MAIN
  csilk_router_add(router, "GET", "/health", (csilk_handler_t[]){ping_handler, NULL}, 1);
  csilk_router_add(router, "GET", "/api/users", (csilk_handler_t[]){get_users_handler, NULL}, 1);
MAIN
    if [ -n "$PERM_ROUTES" ]; then echo "  csilk_router_add_perm(router, \"GET\", \"/admin\", (csilk_handler_t[]){admin_handler, NULL}, 1, \"admin\", \"*\");" >> src/main.c; fi

    cat >> src/main.c <<MAIN

  csilk_server_run(server, ${PORT});
MAIN
    if [ -n "$CLEANUP_DB" ]; then echo "$CLEANUP_DB" >> src/main.c; fi
    cat >> src/main.c <<MAIN
  csilk_server_free(server);
  csilk_router_free(router);
  return 0;
}
MAIN
  fi
}

generate_readme() {
  cat > README.md <<README
# ${PROJECT_NAME}

Generated with [csilk](${CSILK_REPO_DEFAULT}) v${CSILK_VERSION}.

## Architecture

This project follows a layered architecture:

- \`src/api/\`: Handlers and route definitions.
- \`src/service/\`: Business logic layer.
- \`src/model/\`: Data structures and reflection metadata.

## Quick start

\`\`\`bash
mkdir build && cd build
cmake .. 
make
./${PROJECT_NAME}
\`\`\`

## API Documentation

When the server is running, visit:
- **Swagger UI**: http://localhost:${PORT}/docs
- **OpenAPI JSON**: http://localhost:${PORT}/openapi.json

## Endpoints

| Method | Path | Description |
|--------|------|-------------|
| GET | /api/users | List all users |
| POST | /api/users | Create a new user |
README
}

# Main Execution
print_banner
log_step "csilk Project Scaffolding"

# Defaults
PROJECT_NAME=""
OUT_DIR=""
PORT=""
API_STYLE=""
DB=""
AI_PROVIDER=""
USE_CIPHER=""
AUTH=""
USE_PERM=""
USE_SWAGGER=""
MID_CORS="n"
MID_GZIP="n"
MID_RATELIMIT="n"
MID_SESSION="n"
MID_REQUESTID="n"
DO_GIT=""
NON_INTERACTIVE=0

# Parse CLI arguments
while [[ "$#" -gt 0 ]]; do
  case $1 in
    -h|--help) show_help; exit 0 ;;
    -n|--name) PROJECT_NAME="$2"; shift ;;
    -o|--out-dir) OUT_DIR="$2"; shift ;;
    -p|--port) PORT="$2"; shift ;;
    --api-style) API_STYLE="$2"; shift ;;
    --db) DB="$2"; shift ;;
    --ai) AI_PROVIDER="$2"; shift ;;
    --cipher) USE_CIPHER="1" ;;
    --auth) AUTH="$2"; shift ;;
    --use-perm) USE_PERM="1" ;;
    --use-swagger) USE_SWAGGER="1" ;;
    --middleware)
      IFS=',' read -r -a mids <<< "$2"
      for m in "${mids[@]}"; do
        m="${m// /}"
        case "$m" in
          cors) MID_CORS="y" ;;
          gzip) MID_GZIP="y" ;;
          ratelimit) MID_RATELIMIT="y" ;;
          session) MID_SESSION="y" ;;
          requestid) MID_REQUESTID="y" ;;
        esac
      done
      shift
      ;;
    --git) DO_GIT="1" ;;
    --non-interactive) NON_INTERACTIVE=1 ;;
    *) log_error "Unknown parameter passed: $1"; exit 1 ;;
  esac
  shift
done

# Fallback to interactive prompts if not non-interactive
if [ -z "$PROJECT_NAME" ]; then
  if [ "$NON_INTERACTIVE" -eq 1 ]; then PROJECT_NAME="myapp"; else PROJECT_NAME=$(ask "Project name" "myapp"); fi
fi
DIR_NAME="${PROJECT_NAME// /-}"
DIR_NAME="${DIR_NAME,,}"

if [ -z "$OUT_DIR" ]; then
  if [ "$NON_INTERACTIVE" -eq 1 ]; then OUT_DIR="./$DIR_NAME"; else OUT_DIR=$(ask "Output directory" "./$DIR_NAME"); fi
fi

if [ -z "$PORT" ]; then
  if [ "$NON_INTERACTIVE" -eq 1 ]; then PORT="8080"; else PORT=$(ask "Port number" "8080"); fi
fi

if [ -z "$API_STYLE" ]; then
  if [ "$NON_INTERACTIVE" -eq 1 ]; then API_STYLE="app"; else
    API_STYLE=$(pick "API style:" "app" 'app|High-level convenience API (csilk_app_t)
core|Low-level core API (csilk_router_t + csilk_server_t)')
  fi
fi

if [ -z "$DB" ]; then
  if [ "$NON_INTERACTIVE" -eq 1 ]; then DB="sqlite"; else
    DB=$(pick "Database backend:" "sqlite" 'sqlite|SQLite (built-in)
mysql|MySQL (requires libmysqlclient)
postgres|PostgreSQL (requires libpq)
none|No database')
  fi
fi

if [ -z "$AI_PROVIDER" ]; then
  if [ "$NON_INTERACTIVE" -eq 1 ]; then AI_PROVIDER="none"; else
    AI_PROVIDER=$(pick "AI provider:" "none" 'none|No AI support
openai|OpenAI
ollama|Ollama (local)')
  fi
fi

if [ -z "$USE_CIPHER" ]; then
  if [ "$NON_INTERACTIVE" -eq 1 ]; then USE_CIPHER="0"; else
    USE_CIPHER=$(ask_yes "Enable OpenSSL cipher driver" "n" && echo "1" || echo "0")
  fi
fi

if [ -z "$AUTH" ]; then
  if [ "$NON_INTERACTIVE" -eq 1 ]; then AUTH="none"; else
    AUTH=$(pick "Authentication:" "none" 'none|No authentication
jwt|JWT-based authentication
token|Bearer token (simple validator callback)')
  fi
fi

if [ -z "$USE_PERM" ]; then
  if [ "$NON_INTERACTIVE" -eq 1 ]; then USE_PERM="0"; else
    USE_PERM=$(ask_yes "Enable permission system" "n" && echo "1" || echo "0")
  fi
fi

if [ -z "$USE_SWAGGER" ]; then
  if [ "$NON_INTERACTIVE" -eq 1 ]; then USE_SWAGGER="1"; else
    USE_SWAGGER=$(ask_yes "Enable Swagger/OpenAPI" "y" && echo "1" || echo "0")
  fi
fi

if [ "$NON_INTERACTIVE" -eq 0 ]; then
  if [ "$MID_CORS" = "n" ] && [ "$MID_GZIP" = "n" ] && [ "$MID_RATELIMIT" = "n" ] && [ "$MID_SESSION" = "n" ] && [ "$MID_REQUESTID" = "n" ]; then
    echo -e "  ${BOLD}Extra middleware${NC} (comma-separated, e.g. cors,gzip):"
    printf "    cors, gzip, ratelimit, session, requestid\n" >&2
    printf "  choices [none]: " >&2
    IFS=',' read -r -a mid_choices
    for m in "${mid_choices[@]}"; do
      m="${m// /}"
      case "$m" in
        cors) MID_CORS="y" ;;
        gzip) MID_GZIP="y" ;;
        ratelimit) MID_RATELIMIT="y" ;;
        session) MID_SESSION="y" ;;
        requestid) MID_REQUESTID="y" ;;
        none|"") ;;
      esac
    done
  fi
fi

if [ -z "$DO_GIT" ]; then
  if [ "$NON_INTERACTIVE" -eq 1 ]; then DO_GIT="1"; else
    DO_GIT=$(ask_yes "Initialize git repository" "y" && echo "1" || echo "0")
  fi
fi

# Validation
validate_inputs

# Preparation
prepare_vars

# Execution
log_step "Creating project files in $OUT_DIR..."

mkdir -p "$OUT_DIR/src/api"
mkdir -p "$OUT_DIR/src/service"
mkdir -p "$OUT_DIR/src/model"
mkdir -p "$OUT_DIR/public"
touch "$OUT_DIR/public/.gitkeep"

# We must use absolute path for OUT_DIR if we are going to cd
# or just resolve it before cd.
# For simplicity, we cd and then generate.
cd "$OUT_DIR"
generate_gitignore
generate_config
generate_cmake
generate_model
generate_service
generate_api
generate_main
generate_readme

# Git initialization
if [ "$DO_GIT" = "1" ]; then
  if command -v git >/dev/null 2>&1; then
    git init -q
    git add -A
    git commit -m "initial commit from csilkskel" -q || true
    log_success "Git repository initialized."
  else
    log_warn "git command not found, skipping initialization."
  fi
fi

log_success "Project '$PROJECT_NAME' created successfully!"
echo -e "\n  To build and run:"
echo -e "    ${BLUE}cd ${OUT_DIR}${NC}"
echo -e "    ${BLUE}mkdir build && cd build${NC}"
echo -e "    ${BLUE}cmake ..${NC}  (or ${BLUE}cmake .. -DCSILK_SOURCE_DIR=/path/to/csilk${NC})"
echo -e "    ${BLUE}make && ./${PROJECT_NAME}${NC}\n"
